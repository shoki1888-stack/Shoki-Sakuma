  padding: 14px;
  /* iOS-style squircle via large border-radius — softer than a regular rounded rect */
  border-radius: 36px;
  background: linear-gradient(
    135deg,
    rgba(255,255,255,.18) 0%,
    rgba(255,255,255,.06) 38%,
    rgba(255,255,255,.02) 62%,
    rgba(255,255,255,.10) 100%
  );
  -webkit-backdrop-filter: blur(14px) saturate(140%);
          backdrop-filter: blur(14px) saturate(140%);
  /* Edge highlight (top) + soft shadow (bottom) suggesting curved glass */
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.55),
    inset 0 -1px 0 rgba(255,255,255,.10),
    inset 1px 0 0 rgba(255,255,255,.16),
    inset -1px 0 0 rgba(255,255,255,.08),
    0 18px 50px rgba(0,0,0,.18),
    0 2px 6px rgba(0,0,0,.10);
  border: 1px solid rgba(255,255,255,.22);
 }
