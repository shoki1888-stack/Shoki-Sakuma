<script>

 (function cloneMarquee(){
  const row = document.querySelector('.marquee-row');
  if (!row) return;
  const cells = Array.from(row.querySelectorAll('.logo-cell'));

  cells.forEach(cell => {
   const clone = cell.cloneNode(true);
   clone.setAttribute('aria-hidden', 'true');
   row.appendChild(clone);
  });
 })();

 (function setupMediaGalleries(){
  const galleries = document.querySelectorAll('.media-gallery');
  if (!galleries.length) return;

  galleries.forEach((gallery) => {
   const slides = gallery.querySelectorAll('.gallery-slide');
   const dots = gallery.querySelectorAll('.gallery-dot');
   const prevBtn = gallery.querySelector('.gallery-arrow.prev');
   const nextBtn = gallery.querySelector('.gallery-arrow.next');
   if (!slides.length) return;

   let current = 0;
   const COUNT = slides.length;

   function go(idx){
    current = ((idx % COUNT) + COUNT) % COUNT;
    slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
    dots.forEach((d, i) => d.classList.toggle('is-active', i === current));

    slides.forEach((slide, i) => {
     if (i === current) return;
     const iframe = slide.querySelector('iframe.gallery-video');
     if (!iframe) return;
     try {
      iframe.contentWindow.postMessage(
       '{"event":"command","func":"pauseVideo","args":""}',
       '*'
      );
     } catch(_) {}
    });
   }
   const next = () => go(current + 1);
   const prev = () => go(current - 1);

   dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));

   if (prevBtn) prevBtn.addEventListener('click', prev);
   if (nextBtn) nextBtn.addEventListener('click', next);

   let wheelLock = false;
   gallery.addEventListener('wheel', (e) => {

    if (e.target.tagName === 'IFRAME' || e.target.closest('iframe')) return;
    const dx = e.deltaX;
    const dy = e.deltaY;

    if (Math.abs(dx) > Math.abs(dy) * 1.4 && Math.abs(dx) > 8){
     e.preventDefault();
     if (wheelLock) return;
     wheelLock = true;
     if (dx > 0) next(); else prev();
     setTimeout(() => { wheelLock = false; }, 450);
    }
   }, { passive: false });

   let dragStartX = null;
   let dragStartY = null;
   let dragging = false;
   let pointerId = null;

   function onDown(e){

    if (e.target.closest('.gallery-arrow, .gallery-dot')) return;

    if (e.target.tagName === 'IFRAME' || e.target.closest('iframe')) return;
    dragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    pointerId = e.pointerId;
    try { gallery.setPointerCapture(e.pointerId); } catch(_){}
   }
   function onUp(e){
    if (!dragging) return;
    dragging = false;
    const dx = e.clientX - dragStartX;
    const dy = e.clientY - dragStartY;
    if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)){
     if (dx < 0) next(); else prev();
    }
    try { if (pointerId != null) gallery.releasePointerCapture(pointerId); } catch(_){}
   }
   function onCancel(){ dragging = false; }
   gallery.addEventListener('pointerdown', onDown);
   gallery.addEventListener('pointerup', onUp);
   gallery.addEventListener('pointercancel', onCancel);
   gallery.addEventListener('pointerleave', onCancel);

   gallery.setAttribute('tabindex', '0');
   gallery.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight'){ e.preventDefault(); next(); }
    if (e.key === 'ArrowLeft'){  e.preventDefault(); prev(); }
   });

   /* Auto-advance every 4s while visible; honors prefers-reduced-motion */
   const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
   if (!reduceMotion && COUNT > 1){
    let timer = null;
    const tick = () => next();
    const start = () => { if (!timer) timer = setInterval(tick, 4000); };
    const stop  = () => { if (timer){ clearInterval(timer); timer = null; } };
    const visObs = new IntersectionObserver((entries) => {
     entries.forEach(en => en.isIntersecting ? start() : stop());
    }, { threshold: 0.35 });
    visObs.observe(gallery);
    document.addEventListener('visibilitychange', () => {
     if (document.hidden) stop();
    });
   }
  });
 })();

 (function setupFloatingCursor(){

  if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;

  const dot  = document.getElementById("fcDot");
  const ring = document.getElementById("fcRing");
  if (!dot || !ring) return;

  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let ringX = mouseX, ringY = mouseY;
  let dotX  = mouseX, dotY  = mouseY;

  const dotEase  = 0.35;  // small dot follows tightly
  const ringEase = 0.15;  // ring trails softly — the "floating" feel

  document.addEventListener("mousemove", (e) => {
   mouseX = e.clientX;
   mouseY = e.clientY;
   dot.classList.remove("is-hidden");
   ring.classList.remove("is-hidden");
  });

  document.addEventListener("mouseleave", () => {
   dot.classList.add("is-hidden");
   ring.classList.add("is-hidden");
  });

  document.addEventListener("mousedown", () => ring.classList.add("is-clicking"));
  document.addEventListener("mouseup",   () => ring.classList.remove("is-clicking"));

  const hoverSelectors = 'a, button, .nav-link, ' +
             '.theme-toggle, .work-panel, .work-dots .dot, ' +
             '.logo-cell, [role="button"], input, textarea, select';
  document.querySelectorAll(hoverSelectors).forEach(el => {
   el.addEventListener("mouseenter", () => {
    dot.classList.add("is-hovering");
    ring.classList.add("is-hovering");
   });
   el.addEventListener("mouseleave", () => {
    dot.classList.remove("is-hovering");
    ring.classList.remove("is-hovering");
   });
  });

  function tick(){
   dotX  += (mouseX - dotX)  * dotEase;
   dotY  += (mouseY - dotY)  * dotEase;
   ringX += (mouseX - ringX) * ringEase;
   ringY += (mouseY - ringY) * ringEase;

   dot.style.transform  = `translate3d(${dotX}px, ${dotY}px, 0) translate(-50%, -50%)`;
   ring.style.transform = `translate3d(${ringX}px, ${ringY}px, 0) translate(-50%, -50%)`;
   requestAnimationFrame(tick);
  }
  tick();
 })();

