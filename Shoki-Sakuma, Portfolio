  }, { threshold: 0.3 });
  sunriseObs.observe(sunrise);
 }

 (function renderSphere(){
  const canvas = document.getElementById("sunSphere");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");
  const W = canvas.width;
  const H = canvas.height;
  const cx = W / 2;
  const cy = H / 2;
  const R  = Math.min(W, H) * 0.42;

  const N = 900;
  const points = [];
  const goldenAngle = Math.PI * (3 - Math.sqrt(5));
  for (let i = 0; i < N; i++){
   const yNorm = 1 - (i / (N - 1)) * 2;          // -1..1
   const radius = Math.sqrt(1 - yNorm * yNorm);
   const theta = goldenAngle * i;
   const x = Math.cos(theta) * radius;
   const z = Math.sin(theta) * radius;
   points.push({ x, y: yNorm, z });
  }

  let angle = 0;
  function frame(){
   angle += 0.008;  // rotation speed around Y axis

   const tilt = Math.sin(angle * 0.3) * 0.15;

   const isDark = document.documentElement.getAttribute("data-theme") === "dark";
   const dotColor = isDark ? "255,255,255" : "20,20,20";

   ctx.clearRect(0, 0, W, H);

   const cosA = Math.cos(angle), sinA = Math.sin(angle);
   const cosT = Math.cos(tilt),  sinT = Math.sin(tilt);

   for (const p of points){

    let x1 =  p.x * cosA + p.z * sinA;
    let z1 = -p.x * sinA + p.z * cosA;
    let y1 =  p.y;

    const y2 = y1 * cosT - z1 * sinT;
    const z2 = y1 * sinT + z1 * cosT;

    const px = cx + x1 * R;
    const py = cy + y2 * R;

    const depth = (z2 + 1) / 2;          // 0..1
    const alpha = 0.15 + depth * 0.85;
    const radius = 0.6 + depth * 1.4;

    ctx.fillStyle = `rgba(${dotColor},${alpha.toFixed(3)})`;
    ctx.beginPath();
    ctx.arc(px, py, radius, 0, Math.PI * 2);
    ctx.fill();
   }
   requestAnimationFrame(frame);
  }
  frame();
 })();

 const panels = document.querySelectorAll(".work-panel");
 const dots   = document.querySelectorAll(".work-dots .dot");

 const panelObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
   if (entry.isIntersecting) {
    entry.target.classList.add("in-view");
    const idx = parseInt(entry.target.dataset.index, 10);
    dots.forEach((d, i) => d.classList.toggle("active", i === idx));
   }
  });
 }, { threshold: 0.4, rootMargin: "-15% 0px -15% 0px" });

 panels.forEach(p => panelObserver.observe(p));

 dots.forEach(dot => {
  dot.addEventListener("click", () => {
   const idx = parseInt(dot.dataset.target, 10);
   panels[idx].scrollIntoView({ behavior: "smooth", block: "start" });
  });
 });
